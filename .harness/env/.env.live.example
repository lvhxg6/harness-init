# Live image provider settings.
# Copy this file to `.harness/env/.env.live` and fill the real values locally.
# `.harness/env/.env.live` must never be committed or pasted into docs/reports.
# Run with: ./.harness/run-feature.sh activity-checkin-image-generator --live

HARNESS_LIVE_OPENAI=1
IMAGE_PROVIDER=openai

OPENAI_API_KEY=replace-with-your-key
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1

PORT=3001
FRONTEND_PORT=5173
