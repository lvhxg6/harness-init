{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Harness Delivery Report",
  "type": "object",
  "required": [
    "feature",
    "verification_status",
    "stable_status",
    "review_status",
    "live_status",
    "live_pending",
    "implemented_requirements",
    "changed_files",
    "commands_run",
    "evidence",
    "screenshots",
    "risks",
    "human_review_needed",
    "recommended_next_harness_improvements"
  ],
  "properties": {
    "feature": {
      "type": "string"
    },
    "verification_status": {
      "type": "string",
      "enum": ["passed", "failed", "blocked"]
    },
    "stable_status": {
      "type": "string",
      "enum": ["passed", "failed", "blocked", "skipped"]
    },
    "review_status": {
      "type": "string",
      "enum": ["passed", "blocked", "passed_with_live_pending"]
    },
    "live_status": {
      "type": "string",
      "enum": ["not_run", "passed", "failed", "blocked"]
    },
    "live_pending": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implemented_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands_run": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_review_needed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_next_harness_improvements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
